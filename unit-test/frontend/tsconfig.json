{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node16",
    "types": ["jest", "node"],
    "paths": {
      "@frontend/*": ["../../frontend/app/*"],
      "@app/*": ["../../frontend/app/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
