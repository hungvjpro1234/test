        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="PERF-06 Task Detail" enabled="true">
          <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
            <collectionProp name="Arguments.arguments"/>
          </elementProp>
          <stringProp name="HTTPSampler.path">${basePath}/tasks/${__groovy(vars.get('csvTaskId') ?: vars.get('taskId'))}</stringProp>
          <stringProp name="HTTPSampler.method">GET</stringProp>
        </HTTPSamplerProxy>
        <hashTree>
          <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="Task Detail Assertion" enabled="true">
            <collectionProp name="Asserion.test_strings">
              <stringProp name="0">&quot;success&quot;:true</stringProp>
              <stringProp name="1">&quot;title&quot;</stringProp>
