PORT=8080
MONGODB_URI=your_mongodb_uri_here
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=30d

# Cloudinary config
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# File upload limits
MAX_FILE_SIZE=10485760
MAX_FILES_PER_TASK=20

# Firebase
FIREBASE_SERVICE_ACCOUNT_JSON=your_firebase_service_account_json_here

# Realtime & presence
ENABLE_REALTIME_NOTIFICATIONS=true
SOCKET_NAMESPACE=/ws/app
SOCKET_ALLOWED_ORIGINS=http://localhost:3000
SOCKET_HEARTBEAT_INTERVAL_MS=25000
SOCKET_MAX_PAYLOAD_BYTES=5120
PRESENCE_TTL_SECONDS=60

# Redis adapter
ENABLE_SOCKET_REDIS_ADAPTER=false
REDIS_URL=
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_TLS=false